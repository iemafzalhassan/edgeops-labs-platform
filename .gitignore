*.kubeconfig
kubeconfig
*.pem
*.key
*.crt
*.csr

# ===== Helm =====
**/charts/*.tgz
**/*.lock

# ===== Docker =====
.docker/

# ===== IDE =====
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

